{
  "name": "blastcss",
  "version": "1.0.0",
  "description": "A modern, framework-agnostic CSS framework built on cascade layers, OKLCH tokens, container queries, and the popover API.",
  "type": "module",
  "author": {
    "name": "Sitharaj Seenivasan",
    "url": "https://github.com/sitharaj88"
  },
  "funding": [
    { "type": "buymeacoffee", "url": "https://www.buymeacoffee.com/sitharaj88" },
    { "type": "github", "url": "https://github.com/sitharaj88" }
  ],
  "homepage": "https://sitharaj88.github.io/blast-css",
  "bugs": {
    "url": "https://github.com/sitharaj88/blast-css/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sitharaj88/blast-css.git"
  },
  "sideEffects": [
    "*.css"
  ],
  "style": "./dist/blast.min.css",
  "exports": {
    ".": "./dist/blast.min.css",
    "./full": "./dist/blast.min.css",
    "./core": "./dist/blast.core.min.css",
    "./components": "./dist/blast.components.min.css",
    "./components-extra": "./dist/blast.components-extra.min.css",
    "./utilities": "./dist/blast.utilities.min.css",
    "./motion": "./dist/blast.motion.min.css",
    "./reset": "./dist/blast.reset.min.css",
    "./js": "./dist/blast.js",
    "./js/min": "./dist/blast.min.js",
    "./tokens.json": "./dist/tokens.json",
    "./tokens.css": "./dist/tokens.css",
    "./tokens.ts": "./dist/tokens.ts"
  },
  "files": [
    "dist",
    "src",
    "examples",
    "starters",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "benchmark": "node scripts/benchmark.mjs",
    "build": "node scripts/build.mjs",
    "build:docs": "node scripts/build-docs.mjs",
    "build:og": "node scripts/og-images.mjs",
    "build:all": "npm run build && npm run build:docs && npm run build:og",
    "check:exports": "node scripts/export-check.mjs",
    "check:html": "node scripts/html-check.mjs",
    "check:quality": "node scripts/quality-check.mjs",
    "check:size": "node scripts/size-check.mjs",
    "check:visual-manifest": "node scripts/visual-manifest-check.mjs",
    "prepublishOnly": "npm run test:static",
    "test": "npm run test:static",
    "serve": "node scripts/serve.mjs",
    "test:browser": "playwright test",
    "test:browser:chromium": "playwright test --project=chromium",
    "test:static": "npm run build && npm run build:docs && npm run benchmark && npm run check:size && npm run check:quality && npm run check:exports && npm run check:html && npm run check:visual-manifest",
    "test:visual:update": "playwright test tests/browser/visual.spec.js --project=chromium --update-snapshots",
    "verify": "npm run test:static && npm run test:browser"
  },
  "keywords": [
    "css",
    "framework",
    "ui",
    "design-system",
    "oklch",
    "container-queries",
    "popover",
    "cascade-layers",
    "view-transitions",
    "tokens"
  ],
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1"
  }
}
